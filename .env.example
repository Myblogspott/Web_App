# CourtListener API (required for MCP Server)
# Get your token: https://www.courtlistener.com/help/api/rest/#your-authorization-token
COURTLISTENER_API_TOKEN=your-api-key-here

# LLM provider (required for agent backend)
# e.g. OpenAI, Anthropic, or compatible endpoint
OPENAI_API_KEY=your-api-key-here

# Optional: MCP Server base URL (default: http://localhost:8001)
MCP_SERVER_URL=http://localhost:8001

# Optional: Agent backend port (default: 8000)
AGENT_BACKEND_PORT=8000
